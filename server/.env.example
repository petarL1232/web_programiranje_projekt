# Local development configuration. Do not commit server/.env.
NODE_ENV=development
PORT=5000

# A comma-separated allow-list. CLIENT_URL is supported only for backward compatibility.
CLIENT_ORIGINS=http://localhost:4200

MONGO_URI=mongodb://127.0.0.1:27017/documentchain_web
JWT_SECRET=replace-with-a-long-random-local-development-secret
JWT_EXPIRES_IN=1d

# filesystem for local development, mongodb for Render/production.
DOCUMENT_STORAGE=filesystem

# Required only for the small server-side GitHub API integration used by the Overview status card.
SOURCE_REPOSITORY=petarL1232/web_programiranje_projekt
